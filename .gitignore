# GlobeTrek Adventures — .gitignore
# Excludes sensitive files and build artifacts from version control

# ---- Environment Files ----
# NEVER commit .env files — they contain secrets
.env
.env.local
.env.production
.env.*.local

# ---- Node Modules ----
node_modules/
*/node_modules/

# ---- Build Outputs ----
dist/
build/
*/dist/
*/build/

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- OS Files ----
.DS_Store
Thumbs.db
desktop.ini

# ---- Editor/IDE ----
.vscode/settings.json
.idea/
*.swp
*.swo

# ---- Coverage Reports ----
coverage/
.nyc_output/

# ---- Temp scripts ----
backend/seed.js
backend/*.log
frontend/*.log
